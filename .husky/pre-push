#!/usr/bin/env sh
# main push 시 lib/releases.ts entry 추가 강제.
# 누락은 silent miss → Cloudflare 빌드되면 /releases에 안 보임.
# 우회 토큰: 사용자 체감 0인 머지면 commit message에 [skip-release] 추가.
# 정책: AGENTS.md §"릴리스 노트 기록".

while read local_ref local_sha remote_ref remote_sha
do
  # main 외 push는 무관
  if [ "$remote_ref" != "refs/heads/main" ]; then
    continue
  fi

  # commit range 결정 (new branch면 모든 commit, 아니면 remote..local)
  ZERO="0000000000000000000000000000000000000000"
  if [ "$remote_sha" = "$ZERO" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # lib/releases.ts 변경 확인
  if git diff --name-only "$range" 2>/dev/null | grep -q "^lib/releases\.ts$"; then
    echo "✅ main push: lib/releases.ts 변경 감지 — release entry OK"
    continue
  fi

  # 우회 토큰 [skip-release] 검사 (commit body 전체)
  if git log "$range" --format=%B 2>/dev/null | grep -q "\[skip-release\]"; then
    echo "⚠️  main push: lib/releases.ts 변경 없음 + [skip-release] 우회 토큰 발견 → 통과"
    continue
  fi

  # 차단
  echo ""
  echo "❌ main push 차단 — lib/releases.ts 변경 없음"
  echo ""
  echo "   범위: $range"
  echo ""
  echo "   📌 사용자 체감 변화가 있는 머지면:"
  echo "      1. lib/releases.ts 에 새 entry 추가 (id, date, tool, title, body)"
  echo "      2. AGENTS.md §\"릴리스 노트 기록\" 정책 참조"
  echo "      3. 새 commit 후 다시 push"
  echo ""
  echo "   🤫 사용자 체감 0 (internal refactor / 빌드 fix 등):"
  echo "      - 머지 commit message에 [skip-release] 토큰 추가 후 다시 push"
  echo "      - 또는 그냥 main 머지 직전 머지 commit amend로 토큰 삽입"
  echo ""
  exit 1
done

exit 0
